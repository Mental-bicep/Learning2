			String name = rs.getString(3);
			String price = rs.getString(4);
			String quantity = rs.getString(5);
			Integer categoryId = rs.getInt(6);
			System.out.println(productId +"->"+name+"->"+price+"->"+quantity+"->"+categoryId);
			
		}
		
	}
	
	public void update()
    
