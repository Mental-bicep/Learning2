import java.time.LocalDate;
import java.time.LocalTime;

public class IrctcTicketBookingSystem {

    private double walletBalance;
    public static final double BASE_FARE = 500.0; // Made public static for easy access in tests

    public IrctcTicketBookingSystem(double initialBalance) {
        this.walletBalance = initialBalance;
    }

    // NEW METHOD: Expose the calculation logic directly for testing!
    public double calculateFare(int age, LocalDate journeyDate, boolean isTatkal, LocalDate currentDate) {
        double finalFare = BASE_FARE;

        if (age >= 60) {
            finalFare = BASE_FARE * 0.5; 
        } else if (age <= 5) {
            finalFare = 0.0; 
        }

        if (isTatkal) {
            if (!journeyDate.equals(currentDate.plusDays(1))) {
                throw new IllegalArgumentException("Tatkal tickets can only be booked for tomorrow's date");
            }
            finalFare += 150.0; 
        }

        return finalFare;
    }

    public Ticket bookTicket(String passengerName, int age, LocalDate journeyDate, 
                             boolean isTatkal, LocalTime bookingTime, LocalDate currentDate) {
        
        if (age <= 0 || age > 120) {
            throw new IllegalArgumentException("Invalid passenger age provided");
        }
        if (journeyDate.isBefore(currentDate)) {
            throw new IllegalArgumentException("Journey date cannot be in the past");
        }

        // Call the calculation method
        double finalFare = calculateFare(age, journeyDate, isTatkal, currentDate);

        // Simulate server delay for Tatkal window
        if (isTatkal && bookingTime.isAfter(LocalTime.of(10, 59, 59)) && bookingTime.isBefore(LocalTime.of(11, 06, 0))) {
            try { Thread.sleep(150); } catch (InterruptedException e) { Thread.currentThread().interrupt(); }
        }

        // Rule 6: Wallet Check
        if (this.walletBalance < finalFare) {
            throw new IllegalStateException("Insufficient wallet balance! Required: " + finalFare);
        }

        this.walletBalance -= finalFare;
        return new Ticket(passengerName, finalFare, "CONFIRMED");
    }

    public double getWalletBalance() { return this.walletBalance; }
}