package com.profiles.controller;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.profiles.entity.TicketEntity;
import com.profiles.request.BookingRequest;
import com.profiles.service.BookingService;

@RestController
@RequestMapping("/irctc")
public class BookingController {
	
	@Autowired
	BookingService bookingService;
	
	@PostMapping("/bookTicket")
	public TicketEntity bookTicket(@RequestBody BookingRequest req) {
		return bookingService.bookTicket(req);
	}
	
	@GetMapping("/irctc/checkpnr/{pnr}")
	public TicketEntity checkPnrStatus(@PathVariable() Integer pnr ) {
		System.out.println("inside check PNR controller **********************************************************");
		return bookingService.checkPnrStatus(pnr);
	}
}
