public class MultiplyTest {
	
	private Multiply mul ;
	
	@BeforeAll
	public void before() {
		mul = new Multiply();
		System.out.println("About to start the Execution");
	}
	
	@BeforeEach
	public void beforeEach() {
		System.out.println("Starting the testCase");
	}
	
	@AfterEach
	public void afterEach() {
		System.out.println("Testcase completed");
	}
	
	@AfterAll
	public void afterAll() {
		System.out.println("Completed the execution");
		mul = null;
	}
	
	
	@Test
	public void mulTest1() {
		int a = 5, b=8;
		int exp = 40;
		int actual = mul.calc(a, b);
		
		assertEquals(exp, actual);
	}
	
	@Test
	public void mulTest2() {
		int a=0, b=10;
		int exp = 0;
		int actual = mul.calc(a, b);
		assertEquals(exp, actual);
	}
