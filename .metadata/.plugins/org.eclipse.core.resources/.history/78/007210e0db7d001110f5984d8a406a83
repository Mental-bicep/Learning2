package com.zepto.repository;

import java.util.List;
import java.util.Optional;

import org.springframework.data.jpa.repository.EntityGraph;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.CrudRepository;

import com.zepto.entity.CategoryEntity;

public interface CategoryRepository extends CrudRepository<CategoryEntity, Long>{
	
	Optional<CategoryEntity>  findByCategoryName(String name);
	
	@Query("select c from CategoryEntity c left join fetch c.productEntities")
	List<CategoryEntity> findAllCategoriesWithProductEntitesJoinFetch();
	
